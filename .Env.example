# ════════════════════════════════════════════════════════════════════════════════
# XAVIER — Multi-Strategy Quant Trading Bot
# ════════════════════════════════════════════════════════════════════════════════

# ── Alpaca Broker API ──────────────────────────────────────────────────────────
# Sign up free at https://alpaca.markets — always use Paper Trading first
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
# Set to "false" only when ready for live money
ALPACA_PAPER=true

# ── Telegram ───────────────────────────────────────────────────────────────────
XAVIER_TELEGRAM_TOKEN=your_xavier_telegram_bot_token
XAVIER_TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Per-trade risk ─────────────────────────────────────────────────────────────
XAVIER_RISK_PCT=1.0
XAVIER_MIN_RR_RATIO=1.5
XAVIER_ORB_MINUTES=15
XAVIER_MIN_PRICE=5.0
XAVIER_ALLOW_SHORT=false

# ── Position limits ────────────────────────────────────────────────────────────
XAVIER_MAX_POSITIONS=5
XAVIER_MAX_DAY_POSITIONS=3
XAVIER_MAX_SWING_POSITIONS=2

# ── Portfolio-level risk gates ─────────────────────────────────────────────────
XAVIER_MAX_PORTFOLIO_RISK_PCT=6.0
XAVIER_DAILY_LOSS_LIMIT_PCT=3.0
XAVIER_CONSECUTIVE_LOSS_HALT=4
XAVIER_MAX_CRYPTO_ALLOC_PCT=20.0

# ── Strategy feature flags ─────────────────────────────────────────────────────
XAVIER_ENABLE_CRYPTO=true
XAVIER_ENABLE_SWING=true
XAVIER_ENABLE_VWAP_REVERSION=true
XAVIER_ENABLE_MOMENTUM=true
XAVIER_ENABLE_ETF_ROTATION=true

# ── Optional: custom equity watchlist ─────────────────────────────────────────
# Comma-separated tickers. Leave blank to use the full default list.
XAVIER_WATCHLIST=

# ── Control ────────────────────────────────────────────────────────────────────
XAVIER_PAUSED=false
